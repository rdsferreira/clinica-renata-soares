---
// CTA Final + Contato

const whatsapp =
  "https://wa.me/5511988171918?text=Ol%C3%A1%2C%20gostaria%20de%20agendar%20uma%20avalia%C3%A7%C3%A3o";
const mapsHref =
  "https://www.google.com/maps/search/?api=1&query=Alameda+Graja%C3%BA%2C+60+-+Sala+1010%2C+Alphaville+Industrial+-+Barueri%2FSP";
---

<section class="section-wrap" id="contato">
  <div class="container">
    <div class="card-purple contact__inner">
      <div class="contact__header fade-up">
        <p class="eyebrow">Agende agora</p>
        <h2>Agende a avaliação do seu filho</h2>
      </div>

      <div class="contact__cta fade-up fade-up-delay-1">
        <p>
          A primeira consulta é o ponto de partida para entender o que está
          causando a dor e definir o caminho do tratamento. Entre em contato
          e escolha o melhor horário para a sua família.
        </p>
        <div class="contact__actions">
          <a class="btn btn-primary contact__btn-wa" href={whatsapp} target="_blank" rel="noopener">
            <svg width="18" height="18" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true"><path d="M16 2.9C8.8 2.9 2.9 8.7 2.9 16c0 2.6.7 5 2 7.1L3 29l6.1-1.9c2 1.1 4.3 1.7 6.9 1.7 7.2 0 13.1-5.8 13.1-13.1S23.2 2.9 16 2.9Zm6.3 17.8c-.3-.2-2-1-2.3-1.1-.3-.1-.5-.2-.8.2-.2.3-.9 1.1-1.1 1.3-.2.2-.4.3-.7.1-.3-.2-1.3-.5-2.4-1.5-.9-.8-1.5-1.8-1.7-2.1-.2-.3 0-.5.1-.7.2-.2.3-.4.5-.6.2-.2.2-.4.1-.7-.1-.3-.8-2-1.1-2.7-.3-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.4s1 2.8 1.1 3c.1.2 1.9 2.9 4.6 4 2.7 1.1 2.7.7 3.2.7.5 0 1.5-.6 1.7-1.2.2-.6.2-1.1.1-1.2-.1-.1-.3-.2-.5-.3Z"/></svg>
            Agendar pelo WhatsApp
          </a>
          <a class="btn btn-secondary contact__btn-email" href="mailto:fisioterapeutarenata@gmail.com">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 7 10-7"/></svg>
            Enviar e-mail
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact__inner {
    display: block;
  }

  .contact__header {
    margin-bottom: clamp(1.5rem, 1rem + 2vw, 2rem);
  }

  .contact__header h2 {
    font-size: var(--font-h2);
    margin-top: 0.75rem;
    max-width: 28ch;
    text-wrap: balance;
  }

  .contact__cta {
    max-width: 40rem;
    margin-inline: auto;
    text-align: center;
  }

  .contact__cta p {
    max-width: 52ch;
    margin-inline: auto;
    opacity: 0.9;
    line-height: 1.7;
  }

  @media (max-width: 640px) {
    .contact__cta p {
      line-height: 1.45;
    }
  }

  .contact__actions {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.875rem;
    align-items: center;
  }

  .contact__btn-wa,
  .contact__btn-email {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: auto;
    gap: 0.625rem;
    padding: 1rem 1.75rem;
    font-size: 0.9rem;
    white-space: nowrap;
  }

  .contact__btn-email {
    color: #fff;
    border-color: rgb(255 255 255 / 0.3);
  }

  .contact .eyebrow {
    color: var(--color-lime);
  }
</style>
