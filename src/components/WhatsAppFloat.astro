---
const whatsapp =
  "https://wa.me/5511988171918?text=Ol%C3%A1%2C%20gostaria%20de%20agendar%20uma%20avalia%C3%A7%C3%A3o";
---

<a
  class="whatsapp-float"
  href={whatsapp}
  target="_blank"
  rel="noopener"
  aria-label="Falar no WhatsApp"
>
  <svg viewBox="0 0 32 32" aria-hidden="true" focusable="false">
    <path
      fill="currentColor"
      d="M16 2.9C8.8 2.9 2.9 8.7 2.9 16c0 2.6.7 5 2 7.1L3 29l6.1-1.9c2 1.1 4.3 1.7 6.9 1.7 7.2 0 13.1-5.8 13.1-13.1S23.2 2.9 16 2.9Zm0 23.8c-2.3 0-4.5-.6-6.4-1.8l-.5-.3-3.6 1.1 1.1-3.5-.3-.5C5.1 19.7 4.5 17.9 4.5 16c0-6.3 5.2-11.5 11.5-11.5S27.5 9.7 27.5 16 21.8 26.7 16 26.7Zm6.3-8.6c-.3-.2-2-1-2.3-1.1-.3-.1-.5-.2-.8.2-.2.3-.9 1.1-1.1 1.3-.2.2-.4.3-.7.1-.3-.2-1.3-.5-2.4-1.5-.9-.8-1.5-1.8-1.7-2.1-.2-.3 0-.5.1-.7.2-.2.3-.4.5-.6.2-.2.2-.4.1-.7-.1-.3-.8-2-1.1-2.7-.3-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.4s1 2.8 1.1 3c.1.2 1.9 2.9 4.6 4 2.7 1.1 2.7.7 3.2.7.5 0 1.5-.6 1.7-1.2.2-.6.2-1.1.1-1.2-.1-.1-.3-.2-.5-.3Z"
    />
  </svg>
</a>

<style>
  .whatsapp-float {
    position: fixed;
    bottom: 1.25rem;
    right: 1.25rem;
    z-index: 50;
    width: 3.25rem;
    height: 3.25rem;
    border-radius: 50%;
    background: var(--color-accent);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 24px -6px rgb(0 0 0 / 0.35);
    transition: transform 0.15s ease, opacity 0.2s ease;
  }

  .whatsapp-float:hover {
    transform: scale(1.06);
  }

  :global(html.has-cookie-banner) .whatsapp-float {
    opacity: 0;
    pointer-events: none;
    transform: translateY(0.75rem);
  }

  .whatsapp-float svg {
    width: 1.75rem;
    height: 1.75rem;
  }
</style>
