---
// Seção 06 — Diferenciais do Atendimento

const diferenciais = [
  {
    title: "Abordagem Multidisciplinar",
    text: "Integração com pediatras, ortopedistas e reumatologistas para um cuidado completo e coordenado.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  },
  {
    title: "Protocolos Personalizados",
    text: "Tratamentos adaptados à fase de crescimento e desenvolvimento de cada paciente.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>`,
  },
  {
    title: "Comunicação Clara",
    text: "Orientações objetivas para famílias e médicos encaminhadores sobre o andamento do tratamento.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
  },
  {
    title: "Foco em Resultados Duradouros",
    text: "Tratamento direcionado à causa da condição apresentada, não apenas ao alívio dos sintomas.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>`,
  },
];
---

<section class="section" id="diferenciais">
  <div class="container">
    <p class="eyebrow-light fade-up">Por que escolher</p>
    <h2 class="dif__title fade-up fade-up-delay-1">Diferenciais do Atendimento</h2>

    <ul class="dif__grid">
      {
        diferenciais.map((d, i) => (
          <li class={`dif__card fade-up fade-up-delay-${(i % 4) + 1}`}>
            <span class="dif__icon" set:html={d.icon} />
            <h3>{d.title}</h3>
            <p>{d.text}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .eyebrow-light {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-heading);
    font-size: var(--font-small);
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .dif__title {
    font-size: var(--font-h2);
    color: var(--color-text);
    margin-top: 0.75rem;
    max-width: 28ch;
    text-wrap: balance;
  }

  .dif__grid {
    list-style: none;
    padding: 0;
    margin-top: clamp(2.5rem, 2rem + 2vw, 3.5rem);
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
  }

  .dif__card {
    background: var(--color-bg-alt);
    border-radius: 1.25rem;
    padding: clamp(1.5rem, 1.25rem + 1vw, 2rem);
    border: 1px solid var(--color-border);
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .dif__card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 4px 16px -4px rgb(80 42 119 / 0.15);
  }

  .dif__icon {
    display: flex;
    width: 2.5rem;
    height: 2.5rem;
    background: var(--color-accent-tint);
    border-radius: 0.75rem;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
    margin-bottom: 1.25rem;
  }

  .dif__icon svg {
    width: 1.25rem;
    height: 1.25rem;
  }

  .dif__card h3 {
    font-size: var(--font-h3);
    color: var(--color-text);
    margin-bottom: 0.625rem;
  }

  .dif__card p {
    color: var(--color-text-muted);
    font-size: var(--font-small);
    line-height: 1.65;
  }

  @media (max-width: 640px) {
    .dif__card p {
      line-height: 1.45;
    }
  }

  @media (min-width: 600px) {
    .dif__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 960px) {
    .dif__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
