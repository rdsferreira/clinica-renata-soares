---
const whatsapp =
  "https://wa.me/5511988171918?text=Ol%C3%A1%2C%20gostaria%20de%20agendar%20uma%20avalia%C3%A7%C3%A3o";
const mapsUrl =
  "https://www.google.com/maps/search/?api=1&query=Alameda+Graja%C3%BA%2C+60%2C+Alphaville%2C+Barueri%2C+SP";
const wazeUrl =
  "https://waze.com/ul?q=Alameda+Graja%C3%BA%2C+60%2C+Alphaville%2C+Barueri%2C+SP&navigate=yes";
const mapsEmbed =
  "https://maps.google.com/maps?q=Alameda+Graja%C3%BA,+60,+Alphaville,+Barueri,+SP&output=embed&z=16";
---

<footer class="footer">
  <div class="container footer__grid">

    <!-- Bloco esquerdo — Dados da clínica -->
    <div class="footer__col">
      <img
        src="/logo-renata-vertical.svg"
        alt="Clínica Renata Soares — Fisioterapeuta de Crianças e Adolescentes"
        class="footer__brand-logo"
        width="180"
        height="111"
      />

      <address class="footer__address">
        <p>Alameda Grajaú, 60 — Sala 1010</p>
        <p>Alphaville, Barueri — SP, 06454-050</p>
        <p class="footer__hours">Segunda a Sexta: 08h00 às 20h00</p>
      </address>

      <ul class="footer__contacts">
        <li>
          <span class="footer__label">WhatsApp</span>
          <a href={whatsapp} target="_blank" rel="noopener">+55 11 98817-1918</a>
        </li>
        <li>
          <span class="footer__label">E-mail</span>
          <a href="mailto:fisioterapeutarenata@gmail.com">fisioterapeutarenata@gmail.com</a>
        </li>
      </ul>
    </div>

    <!-- Bloco central — Mapa -->
    <div class="footer__col footer__col--map">
      <p class="footer__label footer__label--section footer__label--dropped">Como chegar</p>
      <div class="footer__map-wrap">
        <iframe
          src={mapsEmbed}
          class="footer__map"
          loading="lazy"
          allowfullscreen
          referrerpolicy="no-referrer-when-downgrade"
          title="Localização da Clínica Renata Soares — Alameda Grajaú, 60, Alphaville, Barueri/SP"
        ></iframe>
      </div>
      <div class="footer__map-actions">
        <a class="footer__map-btn" href={mapsUrl} target="_blank" rel="noopener">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>
          Google Maps
        </a>
        <a class="footer__map-btn" href={wazeUrl} target="_blank" rel="noopener">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.54 7.27C19.67 3.65 16.38 1 12.5 1 8.08 1 4.5 4.58 4.5 9c0 .79.1 1.56.3 2.29C3.2 11.93 2 13.37 2 15c0 2.21 1.79 4 4 4h.09A4.5 4.5 0 0 0 10.5 23h3a4.5 4.5 0 0 0 4.41-4H18c2.21 0 4-1.79 4-4 0-1.72-1.09-3.19-2.64-3.77.1-.32.18-.64.18-.96zM9 11.5a1 1 0 1 1 0-2 1 1 0 0 1 0 2zm6 0a1 1 0 1 1 0-2 1 1 0 0 1 0 2z"/></svg>
          Waze
        </a>
      </div>
    </div>

    <!-- Bloco direito — Redes sociais -->
    <div class="footer__col footer__col--social">
      <p class="footer__label footer__label--section footer__label--dropped">Redes sociais</p>
      <ul class="footer__social">
        <li>
          <a
            href="https://instagram.com/renatasoares.com.br"
            target="_blank"
            rel="noopener"
            class="footer__social-link"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><path d="M17.5 6.5h.01"/></svg>
            <span>
              <strong>Instagram</strong>
              <small>@renatasoares.com.br</small>
            </span>
          </a>
        </li>
        <li>
          <a
            href="https://youtube.com/@renatasoares"
            target="_blank"
            rel="noopener"
            class="footer__social-link"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="currentColor" stroke="none"/></svg>
            <span>
              <strong>YouTube</strong>
              <small>@renatasoares</small>
            </span>
          </a>
        </li>
        <li>
          <a
            href="mailto:fisioterapeutarenata@gmail.com"
            class="footer__social-link"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 7 10-7"/></svg>
            <span>
              <strong>E-mail</strong>
              <small>fisioterapeutarenata@gmail.com</small>
            </span>
          </a>
        </li>
      </ul>
    </div>

  </div>

  <!-- Linha final -->
  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <p>CREFITO: <em>3/33415-F</em> · © 2026 Clínica Renata Soares · <a href="/politica-de-privacidade" class="footer__policy-link">Política de Privacidade</a></p>
      <p class="footer__disclaimer">Este site tem caráter informativo e não substitui avaliação profissional.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-accent-dark);
    color: #fff;
    padding-top: clamp(3rem, 2.5rem + 2vw, 5rem);
  }

  .footer__grid {
    display: grid;
    gap: 3rem;
    padding-bottom: clamp(2.5rem, 2rem + 2vw, 4rem);
    border-bottom: 1px solid rgb(255 255 255 / 0.1);
  }

  @media (min-width: 860px) {
    .footer__grid {
      grid-template-columns: 1fr 1.2fr 0.9fr;
      gap: 2.5rem;
    }
  }

  /* Dados da clínica */
  .footer__brand-logo {
    display: block;
    width: auto;
    height: 8.25rem;
    object-fit: contain;
    margin: 0 auto 1rem;
  }

  @media (min-width: 860px) {
    .footer__brand-logo {
      margin-inline: 0;
    }
  }

  .footer__address {
    font-style: normal;
    color: rgb(255 255 255 / 0.65);
    font-size: var(--font-small);
    line-height: 1.75;
  }

  .footer__hours {
    margin-top: 0.75rem;
    color: rgb(255 255 255 / 0.85);
    font-weight: 500;
  }

  .footer__contacts {
    margin-top: 1.25rem;
    display: grid;
    gap: 0.625rem;
  }

  .footer__contacts li {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    font-size: var(--font-small);
  }

  .footer__label {
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-lime);
  }

  .footer__label--section {
    font-size: 0.75rem;
    display: block;
    margin-bottom: 0.875rem;
  }

  /* Desce o título para a altura do logo (que é mais alto que o texto) —
     só faz sentido no desktop, onde as 3 colunas ficam lado a lado */
  @media (min-width: 860px) {
    .footer__label--dropped {
      margin-top: 6.5rem;
    }
  }

  .footer__contacts a {
    color: rgb(255 255 255 / 0.8);
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .footer__contacts a:hover { color: #fff; }

  /* Mapa */
  .footer__map-wrap {
    border-radius: 0.875rem;
    overflow: hidden;
  }

  .footer__map {
    width: 100%;
    height: 200px;
    border: 0;
    display: block;
    filter: grayscale(15%) brightness(0.88);
  }

  .footer__map-actions {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.875rem;
  }

  .footer__map-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    font-weight: 600;
    font-family: var(--font-heading);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-lime);
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .footer__map-btn:hover { color: #fff; }

  /* Redes sociais */
  .footer__social {
    display: grid;
    gap: 1rem;
  }

  .footer__social-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    color: rgb(255 255 255 / 0.75);
    transition: color var(--transition-base);
  }

  .footer__social-link:hover { color: var(--color-lime); }

  .footer__social-link svg {
    flex-shrink: 0;
  }

  .footer__social-link span {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .footer__social-link strong {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 700;
    color: #fff;
  }

  .footer__social-link small {
    font-size: 0.8125rem;
    color: rgb(255 255 255 / 0.55);
  }

  /* Linha final */
  .footer__bottom {
    padding-block: 1.25rem;
    background: rgb(0 0 0 / 0.18);
  }

  .footer__bottom-inner {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    font-size: 0.8125rem;
    color: rgb(255 255 255 / 0.7);
  }

  .footer__bottom-inner em {
    font-style: normal;
    opacity: 0.6;
  }

  .footer__policy-link {
    color: inherit;
    text-decoration: underline;
    transition: color var(--transition-base);
  }

  .footer__policy-link:hover {
    color: var(--color-lime);
  }

  .footer__disclaimer {
    font-size: 0.75rem;
    color: rgb(255 255 255 / 0.6);
  }

  @media (min-width: 640px) {
    .footer__bottom-inner {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }
</style>
