---
import { Image } from "astro:assets";
import heroImage from "../../public/images/foto-hero-02.jpg";

const whatsapp =
  "https://wa.me/5511988171918?text=Ol%C3%A1%2C%20gostaria%20de%20agendar%20uma%20avalia%C3%A7%C3%A3o";
---

<section class="hero" id="topo">
  <div class="container hero__inner">
    <div class="hero__title-wrap fade-up">
      <h1 class="hero__title">
        Fisioterapia especializada para crianças e adolescentes em <span
          class="hero__highlight">Alphaville</span
        >.
      </h1>
    </div>

    <div class="hero__media fade-up fade-up-delay-2">
      <Image
        src={heroImage}
        alt="Dra. Renata Soares avaliando a postura de um paciente infantil em consultório"
        width={1024}
        height={1024}
        class="hero__photo"
      />
    </div>

    <div class="hero__copy fade-up">
      <div class="hero__subtitle">
        <p class="hero__subtitle-lead">Avaliação e tratamento para:</p>
        <ul class="hero__subtitle-list">
          <li>Criança e Adolescentes com Dor</li>
          <li>Lesões esportivas infantojuvenil</li>
          <li>Reumatopediatria</li>
          <li>Ortopedia pediátrica</li>
          <li>Tratamento para escoliose infantojuvenil</li>
        </ul>
        <p class="hero__subtitle-close">Tudo com abordagem humana, acolhimento e totalmente baseado em evidências.</p>
      </div>

      <p class="hero__credential">
        Mestre em Ciências da Saúde pela UNIFESP
      </p>
    </div>

    <div class="hero__cta-wrap fade-up fade-up-delay-3">
      <a
        class="btn btn-primary hero__cta"
        href={whatsapp}
        target="_blank"
        rel="noopener"
      >
        <svg width="18" height="18" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true">
          <path d="M16 2.9C8.8 2.9 2.9 8.7 2.9 16c0 2.6.7 5 2 7.1L3 29l6.1-1.9c2 1.1 4.3 1.7 6.9 1.7 7.2 0 13.1-5.8 13.1-13.1S23.2 2.9 16 2.9Zm6.3 17.8c-.3-.2-2-1-2.3-1.1-.3-.1-.5-.2-.8.2-.2.3-.9 1.1-1.1 1.3-.2.2-.4.3-.7.1-.3-.2-1.3-.5-2.4-1.5-.9-.8-1.5-1.8-1.7-2.1-.2-.3 0-.5.1-.7.2-.2.3-.4.5-.6.2-.2.2-.4.1-.7-.1-.3-.8-2-1.1-2.7-.3-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.4s1 2.8 1.1 3c.1.2 1.9 2.9 4.6 4 2.7 1.1 2.7.7 3.2.7.5 0 1.5-.6 1.7-1.2.2-.6.2-1.1.1-1.2-.1-.1-.3-.2-.5-.3Z"/>
        </svg>
        Agendar Avaliação
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    background: var(--color-accent);
    color: #fff;
    overflow: hidden;
  }

  .hero__inner {
    display: grid;
    gap: 1.25rem;
    align-items: center;
    padding-top: clamp(6.5rem, 5.5rem + 3vw, 7rem);
    padding-bottom: clamp(1.5rem, 1rem + 1.5vw, 2.5rem);
  }

  /* 60/40 no desktop */
  @media (min-width: 860px) {
    .hero__inner {
      grid-template-columns: 53fr 47fr;
      gap: 1.5rem;
      padding-bottom: clamp(2rem, 1.5rem + 1.5vw, 3rem);
    }

    .hero__title-wrap {
      grid-column: 1;
      grid-row: 1;
    }

    .hero__media {
      grid-column: 2;
      grid-row: 1 / span 2;
    }

    .hero__copy {
      grid-column: 1;
      grid-row: 2;
    }
  }

  .hero__title-wrap,
  .hero__copy {
    max-width: 36rem;
  }

  .hero__title {
    font-size: var(--font-display);
    line-height: 1.1;
    letter-spacing: -0.02em;
    text-wrap: balance;
  }

  @media (max-width: 640px) {
    .hero__title {
      line-height: 1.25;
    }
  }

  .hero__highlight {
    color: var(--color-orange);
  }

  .hero__subtitle {
    margin-top: 1.25rem;
    font-size: var(--font-body);
    text-transform: none;
    font-family: var(--font-body-family);
    color: rgb(255 255 255 / 0.88);
    max-width: 44ch;
    line-height: 1.7;
  }

  @media (max-width: 640px) {
    .hero__subtitle {
      font-size: 0.875rem;
      line-height: 1.45;
    }
  }

  .hero__subtitle-lead {
    font-weight: 600;
    color: rgb(255 255 255 / 0.95);
    margin-bottom: 0.25rem;
  }

  .hero__subtitle-list {
    list-style: none;
    padding: 0;
    margin: 0 0 0.875rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .hero__subtitle-list li::before {
    content: "· ";
    color: var(--color-lime);
    font-weight: 700;
  }

  .hero__subtitle-close {
    font-style: italic;
    color: rgb(255 255 255 / 0.7);
    font-size: 0.9em;
  }

  .hero__cta-wrap {
    grid-column: 1 / -1;
    display: flex;
    justify-content: center;
    padding-bottom: clamp(1rem, 0.5rem + 1vw, 2rem);
  }

  .hero__cta {
    padding: 1.125rem 2.5rem;
    font-size: 0.9375rem;
    box-shadow: 0 12px 32px -8px rgb(0 0 0 / 0.4), 0 0 0 1px rgb(255 255 255 / 0.15) inset;
  }

  .hero__cta:hover {
    box-shadow: 0 16px 40px -8px rgb(0 0 0 / 0.5), 0 0 0 1px rgb(255 255 255 / 0.25) inset;
    transform: translateY(-2px);
  }

  .hero__credential {
    margin-top: 1.5rem;
    font-size: 0.8125rem;
    font-family: var(--font-body-family);
    text-transform: none;
    color: rgb(255 255 255 / 0.6);
    letter-spacing: 0.01em;
  }

  .hero__media {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .hero__photo {
    width: 100%;
    height: auto;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: var(--radius-card);
  }

  .hero__pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
  }
</style>
