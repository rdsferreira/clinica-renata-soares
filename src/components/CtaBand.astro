---
// Faixa de CTA intermediária — reutilizada entre seções para multiplicar pontos de conversão
interface Props {
  text: string;
  buttonLabel?: string;
}

const { text, buttonLabel = "Agendar Avaliação" } = Astro.props;

const whatsapp =
  "https://wa.me/5511988171918?text=Ol%C3%A1%2C%20gostaria%20de%20agendar%20uma%20avalia%C3%A7%C3%A3o";
---

<section class="section-wrap cta-band-section">
  <div class="container">
    <div class="card-purple cta-band fade-up">
      <p class="cta-band__text">{text}</p>
      <a class="cta-band__btn" href={whatsapp} target="_blank" rel="noopener">
        <svg width="18" height="18" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true"><path d="M16 2.9C8.8 2.9 2.9 8.7 2.9 16c0 2.6.7 5 2 7.1L3 29l6.1-1.9c2 1.1 4.3 1.7 6.9 1.7 7.2 0 13.1-5.8 13.1-13.1S23.2 2.9 16 2.9Zm6.3 17.8c-.3-.2-2-1-2.3-1.1-.3-.1-.5-.2-.8.2-.2.3-.9 1.1-1.1 1.3-.2.2-.4.3-.7.1-.3-.2-1.3-.5-2.4-1.5-.9-.8-1.5-1.8-1.7-2.1-.2-.3 0-.5.1-.7.2-.2.3-.4.5-.6.2-.2.2-.4.1-.7-.1-.3-.8-2-1.1-2.7-.3-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.4s1 2.8 1.1 3c.1.2 1.9 2.9 4.6 4 2.7 1.1 2.7.7 3.2.7.5 0 1.5-.6 1.7-1.2.2-.6.2-1.1.1-1.2-.1-.1-.3-.2-.5-.3Z"/></svg>
        {buttonLabel}
      </a>
    </div>
  </div>
</section>

<style>
  .cta-band {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 1.5rem;
  }

  .cta-band__text {
    color: #fff;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.0625rem;
    max-width: 34rem;
    text-wrap: balance;
  }

  /* ---- Liquid Glass — mesmo material iOS: specular, refração, shimmer ---- */
  .cta-band__btn {
    position: relative;
    overflow: hidden;
    flex-shrink: 0;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
    min-height: 44px;
    padding: 1rem 1.75rem;
    border-radius: 999px;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--font-small);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    text-decoration: none;
    color: #fff;
    background: rgb(255 255 255 / 0.16);
    backdrop-filter: blur(28px) saturate(2.2) brightness(1.15);
    -webkit-backdrop-filter: blur(28px) saturate(2.2) brightness(1.15);
    border: 1px solid rgb(255 255 255 / 0.55);
    box-shadow:
      0 8px 32px -4px rgb(0 0 0 / 0.3),
      inset 0 1.5px 0 rgb(255 255 255 / 0.7),
      inset 0 -1px 0 rgb(0 0 0 / 0.15),
      inset 1.5px 0 0 rgb(255 255 255 / 0.22);
    transition: transform 0.22s ease, box-shadow 0.22s ease, background 0.22s ease;
  }

  .cta-band__btn::before {
    content: "";
    position: absolute;
    inset: 0;
    bottom: 50%;
    background: linear-gradient(to bottom, rgb(255 255 255 / 0.3) 0%, rgb(255 255 255 / 0.05) 100%);
    border-radius: inherit;
    pointer-events: none;
  }

  .cta-band__btn::after {
    content: "";
    position: absolute;
    inset: -60%;
    background: linear-gradient(
      108deg,
      transparent 33%,
      rgb(255 255 255 / 0.16) 48%,
      rgb(255 255 255 / 0.26) 50%,
      rgb(255 255 255 / 0.16) 52%,
      transparent 67%
    );
    transform: translateX(-120%) rotate(12deg);
    transition: transform 0.55s ease;
    pointer-events: none;
  }

  .cta-band__btn:hover::after {
    transform: translateX(120%) rotate(12deg);
  }

  .cta-band__btn:hover {
    background: rgb(255 255 255 / 0.24);
    box-shadow:
      0 12px 40px -4px rgb(0 0 0 / 0.38),
      inset 0 1.5px 0 rgb(255 255 255 / 0.85),
      inset 0 -1px 0 rgb(0 0 0 / 0.1),
      inset 1.5px 0 0 rgb(255 255 255 / 0.32);
    transform: translateY(-2px);
  }

  @media (max-width: 640px) {
    .cta-band__text {
      max-width: none;
    }

    .cta-band__btn {
      width: 100%;
    }
  }

  /* Faixa é exclusiva do mobile — no desktop as seções já têm CTA suficiente (header + hero + final) */
  @media (min-width: 641px) {
    .cta-band-section {
      display: none;
    }
  }
</style>
