---
// Seção 09 — Trabalho integrado com médicos
const whatsapp =
  "https://wa.me/5511988171918?text=Ol%C3%A1%2C%20sou%20m%C3%A9dico%28a%29%20e%20gostaria%20de%20falar%20sobre%20um%20paciente";
---

<section class="section" id="medicos">
  <div class="container medpartners__inner">
    <div class="medpartners__copy">
      <p class="eyebrow-light">Para médicos e especialistas</p>
      <h2>Trabalho com equipe multidisciplinar</h2>
      <p>
        A comunicação entre profissionais de saúde é parte importante do
        processo terapêutico.
      </p>
      <p>
        Por isso, a clínica mantém uma atuação próxima a pediatras, ortopedistas,
        reumatologistas e demais especialistas envolvidos no cuidado do paciente.
      </p>
      <p>
        Quando necessário, são elaborados relatórios evolutivos e devolutivas
        técnicas para acompanhamento conjunto.
      </p>

      <a class="medpartners__cta" href={whatsapp} target="_blank" rel="noopener">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        Falar com a Equipe
      </a>
    </div>

    <ul class="medpartners__cards">
      <li class="medpartners__card">
        <span class="medpartners__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
            <polyline points="10 9 9 9 8 9"/>
          </svg>
        </span>
        <h3>Relatórios Evolutivos</h3>
        <p>Documentação técnica periódica sobre a evolução do paciente para médicos encaminhadores.</p>
      </li>
      <li class="medpartners__card">
        <span class="medpartners__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.36 11a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21 16.92z"/>
          </svg>
        </span>
        <h3>Canal Direto</h3>
        <p>Contato facilitado para discussão de casos e alinhamento de condutas terapêuticas.</p>
      </li>
      <li class="medpartners__card">
        <span class="medpartners__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
        </span>
        <h3>Atuação Integrada</h3>
        <p>Parceria com pediatras, ortopedistas e reumatologistas para cuidado multidisciplinar do paciente.</p>
      </li>
    </ul>
  </div>
</section>

<style>
  .eyebrow-light {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-heading);
    font-size: var(--font-small);
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .medpartners__inner {
    display: grid;
    gap: clamp(2.5rem, 2rem + 2vw, 4rem);
    align-items: start;
  }

  .medpartners__copy h2 {
    font-size: var(--font-h2);
    color: var(--color-text);
    margin-top: 0.75rem;
    max-width: 26ch;
    text-wrap: balance;
  }

  .medpartners__copy p {
    margin-top: 1.25rem;
    color: var(--color-text-muted);
    max-width: 44ch;
  }

  .medpartners__cards {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 1rem;
  }

  .medpartners__card {
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-accent);
    border-radius: 1rem;
    padding: 1.5rem;
  }

  .medpartners__icon {
    display: flex;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 0.625rem;
    background: var(--color-accent-tint);
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .medpartners__icon svg {
    width: 1.125rem;
    height: 1.125rem;
  }

  .medpartners__card h3 {
    font-size: 1rem;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  .medpartners__card p {
    font-size: var(--font-small);
    color: var(--color-text-muted);
    line-height: 1.65;
  }

  @media (max-width: 640px) {
    .medpartners__card p {
      line-height: 1.45;
    }
  }

  /* ---- Liquid Glass roxo — preenchimento roxo sólido + borda esbranquiçada, igual aos demais CTAs do site ---- */
  .medpartners__cta {
    display: none;
    position: relative;
    overflow: hidden;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
    min-height: 44px;
    padding: 1rem 1.75rem;
    border-radius: 999px;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--font-small);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    text-decoration: none;
    color: #fff;
    background: var(--color-accent);
    backdrop-filter: blur(20px) saturate(1.8) brightness(1.05);
    -webkit-backdrop-filter: blur(20px) saturate(1.8) brightness(1.05);
    border: 1px solid rgb(255 255 255 / 0.4);
    box-shadow:
      0 8px 24px -6px rgb(80 42 119 / 0.4),
      inset 0 1.5px 0 rgb(255 255 255 / 0.35),
      inset 0 -1px 0 rgb(0 0 0 / 0.15);
    transition: transform 0.22s ease, box-shadow 0.22s ease, background 0.22s ease;
  }

  .medpartners__cta::before {
    content: "";
    position: absolute;
    inset: 0;
    bottom: 50%;
    background: linear-gradient(to bottom, rgb(255 255 255 / 0.22) 0%, transparent 100%);
    border-radius: inherit;
    pointer-events: none;
  }

  .medpartners__cta::after {
    content: "";
    position: absolute;
    inset: -60%;
    background: linear-gradient(
      108deg,
      transparent 33%,
      rgb(255 255 255 / 0.14) 48%,
      rgb(255 255 255 / 0.22) 50%,
      rgb(255 255 255 / 0.14) 52%,
      transparent 67%
    );
    transform: translateX(-120%) rotate(12deg);
    transition: transform 0.55s ease;
    pointer-events: none;
  }

  .medpartners__cta:hover::after {
    transform: translateX(120%) rotate(12deg);
  }

  .medpartners__cta:hover {
    background: var(--color-accent-dark);
    box-shadow:
      0 12px 32px -6px rgb(80 42 119 / 0.5),
      inset 0 1.5px 0 rgb(255 255 255 / 0.45),
      inset 0 -1px 0 rgb(0 0 0 / 0.15);
    transform: translateY(-2px);
  }

  @media (min-width: 860px) {
    .medpartners__inner {
      grid-template-columns: 1fr 1fr;
    }

    .medpartners__cta {
      display: inline-flex;
      margin-top: 2rem;
    }
  }
</style>
