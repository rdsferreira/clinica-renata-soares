---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import PediatricCare from "../components/PediatricCare.astro";
import Methodology from "../components/Methodology.astro";
import HowItWorks from "../components/HowItWorks.astro";
import About from "../components/About.astro";
import Diferenciais from "../components/Diferenciais.astro";
import Ambiente from "../components/Ambiente.astro";
import Galeria from "../components/Galeria.astro";
import Testimonials from "../components/Testimonials.astro";
import MedicalPartners from "../components/MedicalPartners.astro";
import FAQ from "../components/FAQ.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
import WhatsAppFloat from "../components/WhatsAppFloat.astro";
import CookieConsent from "../components/CookieConsent.astro";
---

<Layout
  title="Clínica Renata Soares — Fisioterapia Pediátrica em Alphaville"
  description="Fisioterapia especializada para crianças e adolescentes em Alphaville, Barueri/SP. Avaliação e tratamento de dores, alterações posturais, lesões esportivas e condições musculoesqueléticas com base em evidências. Agende uma avaliação."
  ogImage="/og-image.jpg"
>
  <Header />
  <main>
    <Hero />
    <PediatricCare />
    <Methodology />
    <HowItWorks />
    <About />
    <Diferenciais />
    <Ambiente />
    <Galeria />
    <Testimonials />
    <MedicalPartners />
    <FAQ />
    <Contact />
  </main>
  <Footer />
  <WhatsAppFloat />
  <CookieConsent />
</Layout>
